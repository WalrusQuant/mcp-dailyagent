# ===========================================
# Required
# ===========================================

# Supabase - get from Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Encryption key for storing provider API keys in the database (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Use the same key across all deployments. Changing it invalidates stored API keys.
ENCRYPTION_KEY=

# Secret code users must enter to create an account
# Remove or leave empty to disable signups entirely
SIGNUP_SECRET=your-secret-code

# ===========================================
# Optional
# ===========================================

# Tavily - get key at https://tavily.com
# Enables the web search toggle in the chat input
# TAVILY_API_KEY=tvly-...

# Model used to auto-generate conversation titles (pick something fast/cheap)
# TITLE_MODEL=google/gemini-3-flash-preview

# Default model for chat (default: anthropic/claude-sonnet-4.5)
# DEFAULT_CHAT_MODEL=anthropic/claude-sonnet-4.5

# Default model for image generation (default: google/gemini-2.5-flash-image)
# DEFAULT_IMAGE_MODEL=google/gemini-2.5-flash-image

# App name shown in UI and meta tags (default: Daily Agent)
# NEXT_PUBLIC_SITE_NAME=Daily Agent

# Meta description (default: Your AI productivity agent)
# NEXT_PUBLIC_SITE_DESCRIPTION=Your AI productivity agent

# ===========================================
# Provider API keys are managed from the Admin panel in the app.
# They are stored encrypted in the database — not in env vars.
# Models are also managed from the Settings page in the app.
# ===========================================
