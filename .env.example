# ===========================================
# Required
# ===========================================

# Supabase - get from Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Encryption key for storing provider API keys in the database (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ===========================================
# Email (Resend)
# ===========================================

# Resend API key - get from https://resend.com
RESEND_API_KEY=re_...

# From email address (must be verified in Resend)
# FROM_EMAIL=Daily Agent <noreply@dailyagent.dev>

# ===========================================
# Stripe (Phase 7)
# ===========================================

# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...

# ===========================================
# Ory Hydra (Phase 5)
# ===========================================

# HYDRA_PUBLIC_URL=https://auth.dailyagent.dev
# HYDRA_ADMIN_URL=http://hydra:4445
# MCP_SERVER_URL=https://dailyagent.dev/api/mcp
# HYDRA_SYSTEM_SECRET=

# ===========================================
# Optional
# ===========================================

# App name shown in UI and meta tags (default: Daily Agent)
# NEXT_PUBLIC_SITE_NAME=Daily Agent

# Meta description (default: Your AI productivity agent)
# NEXT_PUBLIC_SITE_DESCRIPTION=Your AI productivity agent

# App URL for email links (default: https://dailyagent.dev)
# NEXT_PUBLIC_APP_URL=https://dailyagent.dev

# ===========================================
# Provider API keys are managed from the Admin panel in the app.
# They are stored encrypted in the database — not in env vars.
# ===========================================
