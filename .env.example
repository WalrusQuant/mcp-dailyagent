# ---- Required ----

# A UUID identifying the single user of this instance. Generate one with:
#   uuidgen  (macOS/Linux)
#   python -c "import uuid; print(uuid.uuid4())"
# The container auto-seeds a profiles row with this ID on first start.
SELF_HOSTED_USER_ID=

# Bearer token that the OpenClaw agent sends on every /api/mcp request.
# Generate a long random string, e.g.:
#   openssl rand -hex 32
MCP_API_KEY=

# ---- Recommended ----

# Password for the built-in Postgres container. Pick something random.
POSTGRES_PASSWORD=changeme

# ---- Optional ----

# Email stored on the profile row. Only visible to you.
SELF_HOSTED_USER_EMAIL=user@localhost

# Branding shown in the dashboard.
NEXT_PUBLIC_SITE_NAME=Daily Agent MCP
NEXT_PUBLIC_SITE_DESCRIPTION=Your productivity dashboard

# Postgres user + db name (change if you know why).
POSTGRES_USER=dailyagent
POSTGRES_DB=dailyagent
