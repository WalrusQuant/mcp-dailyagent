# ===========================================
# Database (local Postgres in docker-compose)
# ===========================================

DATABASE_URL=postgres://dailyagent:dailyagent@localhost:5432/dailyagent

# Override the Postgres container credentials (optional)
# POSTGRES_USER=dailyagent
# POSTGRES_PASSWORD=dailyagent
# POSTGRES_DB=dailyagent

# ===========================================
# Single-user identity
# ===========================================

# The UUID for the single user. Any valid UUID. Seeded into the profiles table on first run.
# Generate with: node -e "console.log(require('crypto').randomUUID())"
SELF_HOSTED_USER_ID=

# ===========================================
# MCP server auth
# ===========================================

# Bearer token OpenClaw must send on every /api/mcp request.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MCP_API_KEY=

# ===========================================
# Optional
# ===========================================

# App name shown in UI and meta tags (default: Daily Agent)
# NEXT_PUBLIC_SITE_NAME=Daily Agent

# Meta description (default: Your productivity dashboard)
# NEXT_PUBLIC_SITE_DESCRIPTION=Your productivity dashboard
